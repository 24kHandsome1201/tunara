{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tunara",
  "version": "1.14.0",
  "identifier": "dev.tunara.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist",
    "removeUnusedCommands": true
  },
  "app": {
    "windows": [
      {
        "title": "Tunara",
        "width": 1200,
        "height": 800,
        "minWidth": 640,
        "minHeight": 480,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 18, "y": 18 },
        "visible": true
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost https:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "entitlements": "Entitlements.plist"
    },
    "linux": {
      "deb": {
        "section": "utils",
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0"]
      },
      "rpm": {
        "depends": ["webkit2gtk4.1", "gtk3"]
      },
      "appimage": {
        "bundleMediaFramework": true
      }
    },
    "category": "DeveloperTool",
    "shortDescription": "Terminal with an intelligent session sidebar",
    "longDescription": "Tunara is a real Tauri/xterm terminal with an intelligent session sidebar and a read-only review rail for terminal workflows."
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM4ODBGNzEwODY0NjA4NzMKUldSekNFYUdFUGVBeURIcFRSY3cyYkhPQlE5RHo5c0dLdjlHQXJ1K05RbkhMYXZncWxFS1VSS2MK",
      "endpoints": [
        "https://github.com/24kHandsome1201/tunara/releases/latest/download/latest.json"
      ]
    }
  }
}
