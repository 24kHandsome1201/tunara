{
  "name": "tunara",
  "description": "A real Tauri/xterm terminal with an intelligent session sidebar and read-only review rail.",
  "license": "Apache-2.0",
  "author": "Tunara contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/24kHandsome1201/tunara.git"
  },
  "bugs": {
    "url": "https://github.com/24kHandsome1201/tunara/issues"
  },
  "homepage": "https://github.com/24kHandsome1201/tunara#readme",
  "packageManager": "pnpm@9.15.4",
  "version": "1.16.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test:node": "node --experimental-strip-types --test tests/*.test.mjs",
    "typecheck:ui": "tsc --noEmit -p tsconfig.ui.json",
    "test:ui": "pnpm typecheck:ui && vitest run --config vitest.config.ts",
    "test": "pnpm test:node && pnpm test:ui && cargo test --manifest-path src-tauri/Cargo.toml",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev --config src-tauri/tauri.conf.dev.json"
  },
  "dependencies": {
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-autostart": "~2.5.1",
    "@tauri-apps/plugin-dialog": "~2.7.1",
    "@tauri-apps/plugin-global-shortcut": "~2.3.2",
    "@tauri-apps/plugin-log": "~2.8.0",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-os": "~2.3.2",
    "@tauri-apps/plugin-process": "~2.3.1",
    "@tauri-apps/plugin-store": "~2.4.3",
    "@tauri-apps/plugin-updater": "~2.10.1",
    "@tauri-apps/plugin-window-state": "~2.4.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-image": "^0.9.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2.11.4",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "happy-dom": "^20.10.6",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^7.3.6",
    "vitest": "^4.1.10"
  }
}
